---
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: "tags/{{ tag | slug }}/index.html"
layout: base.njk
---
<h1>Tag: {{ tag }}</h1>
<ul>
  {% for post in collections[tag] | reverse %}
    <li>
      <span class="date">{{ post.date | readableDate }}</span>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
    </li>
  {% endfor %}
</ul>
